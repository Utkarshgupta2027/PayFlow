# Backend deployment
SPRING_PROFILES_ACTIVE=mysql
SPRING_DATASOURCE_URL=jdbc:mysql://host:4000/payflow?useSSL=true&requireSSL=true&enabledTLSProtocols=TLSv1.2,TLSv1.3&verifyServerCertificate=true&useUnicode=true&characterEncoding=UTF-8
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Generate strong, unique values for these before deploy.
JWT_SECRET=
JWT_REFRESH_SECRET=

# Email service
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-gmail-address@gmail.com
MAIL_PASS=your-google-app-password
MAIL_CONNECTION_TIMEOUT=5000
MAIL_TIMEOUT=5000
MAIL_WRITE_TIMEOUT=5000

# Brevo HTTP API (recommended on Render if SMTP port 587 times out).
# Use a Brevo API key from SMTP & API -> API Keys. Do not use the SMTP key/password here.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=verified-sender@example.com

# Optional SMS OTP service
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Frontend deployment
VITE_API_URL=
